# PostgreSQL (pgvector)
PGHOST=localhost
PGPORT=5432
PGDATABASE=oracle_ai
PGUSER=ai_dba
PGPASSWORD=change_me

# Embedding model (Sentence Transformers)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ollama (OpenAI-compatible API)
OLLAMA_BASE_URL=http://localhost:11434/v1
